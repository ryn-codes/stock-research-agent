# =============================================================================
# ResearchGPT — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:GpwRuYlBlt4T4m1U@localhost:5432/researchgpt

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# -----------------------------------------------------------------------------
# Search APIs
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-your-tavily-key-here
EXA_API_KEY=your-exa-key-here

# -----------------------------------------------------------------------------
# Financial Data
# -----------------------------------------------------------------------------
FMP_API_KEY=your-fmp-key-here

# -----------------------------------------------------------------------------
# Observability (LangSmith)
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_PROJECT=researchgpt

# -----------------------------------------------------------------------------
# Application Config
# -----------------------------------------------------------------------------
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=3600
RATE_LIMIT_MAX=10

# -----------------------------------------------------------------------------
# Cost Guardrails (USD)
# -----------------------------------------------------------------------------
MAX_COST_PER_RUN=5.00
SOFT_COST_LIMIT_PER_RUN=3.00
